{
  "name": "wallacast-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend API for Wallacast - Wallabag-compatible read-it-later with TTS",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && npm run copy-sql",
    "copy-sql": "copyfiles -u 1 \"src/database/**/*.sql\" dist/",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@google/genai": "^1.39.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jsdom": "^27.0.0",
    "bcrypt": "^6.0.0",
    "cheerio": "^1.2.0",
    "copyfiles": "^2.4.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-basic-auth": "^1.2.1",
    "fluent-ffmpeg": "^2.1.3",
    "got-scraping": "^4.1.3",
    "jsdom": "^27.4.0",
    "jsonwebtoken": "^9.0.3",
    "node-fetch": "^3.3.2",
    "openai": "^4.24.1",
    "pg": "^8.11.3",
    "seqalign": "^1.0.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.33",
    "@types/pg": "^8.10.9",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
