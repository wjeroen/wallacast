{
  "name": "readcast-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend API for Readcast",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && mkdir -p dist/database/migrations && cp src/database/*.sql dist/database/ && cp src/database/migrations/*.sql dist/database/migrations/",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jsdom": "^27.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-basic-auth": "^1.2.1",
    "fluent-ffmpeg": "^2.1.3",
    "jsdom": "^27.4.0",
    "linkedom": "^0.18.12",
    "node-fetch": "^3.3.2",
    "openai": "^4.24.1",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.10.9",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
